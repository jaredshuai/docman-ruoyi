<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dromara.docman.mapper.DocProjectOrderMapper">

    <!-- 查询项目的签证单列表 -->
    <select id="selectVoListByProjectId" resultType="org.dromara.docman.domain.vo.DocProjectOrderVo">
        SELECT
            id,
            project_id,
            reason,
            `date`,
            amount,
            remark,
            create_by,
            create_time,
            update_time
        FROM doc_project_order
        WHERE del_flag = '0'
          AND project_id = #{projectId}
        ORDER BY create_time DESC
    </select>

</mapper>
